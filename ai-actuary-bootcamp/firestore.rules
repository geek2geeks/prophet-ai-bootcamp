rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email list — mirrors src/app/admin/page.tsx ADMIN_EMAILS
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        "fixola1986@gmail.com"
      ];
    }

    match /students/{userId} {
      // Owner can read/write their own record; admin can read all
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /submissions/{submissionId} {
      // Owner can read/write their submissions; admin can read all
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    match /config/{document=**} {
      // All authenticated users can read; only admin can write
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
